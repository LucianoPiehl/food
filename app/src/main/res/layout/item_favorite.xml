<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.example.food.ui.FavoritesViewModel" />
        <variable
            name="recipe"
            type="com.example.food.model.SingleRecipeDTO" />

    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardBackgroundColor="@color/brand_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/brand_line"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="190dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_image_placeholder">

                    <ImageView
                        android:id="@+id/recipeImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        tools:src="@tools:sample/avatars" />

                    <ImageView
                        android:id="@+id/favoriteIcon2"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="12dp"
                        android:background="@drawable/bg_icon_surface"
                        android:contentDescription="@string/detail_favorite_content"
                        android:padding="9dp"
                        android:src="@drawable/estrella_on" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/recipeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:maxLines="2"
                android:textColor="@color/brand_text"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Recipe Title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_soft_chip"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="@string/recipe_card_hint"
                android:textColor="@color/brand_muted"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
